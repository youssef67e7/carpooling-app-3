{
  "name": "ride-hail-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:EXPO_NO_DEPENDENCY_VALIDATION='1'; npx expo start --lan\"",
    "start:dev-client": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:EXPO_NO_DEPENDENCY_VALIDATION='1'; npx expo start --lan --dev-client\"",
    "start:tunnel": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:EXPO_NO_DEPENDENCY_VALIDATION='1'; npx expo start --tunnel --dev-client\"",
    "start:offline": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:EXPO_NO_DEPENDENCY_VALIDATION='1'; npx expo start --offline\"",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "api-proxy": "node scripts/dev-api-proxy.js"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^13.0.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@reduxjs/toolkit": "^2.5.0",
    "axios": "^1.7.9",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "i18next": "^24.2.0",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-i18next": "^15.4.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webrtc": "^124.0.6",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3"
  }
}
