# Backend API — MongoDB is on the server (backend/.env → MONGODB_URI).
#
# Option A — phone talks to API on port 3000: set EXPO_PUBLIC_API_URL=http://localhost:3000 and open
#   firewall for TCP 3000 (backend/scripts/allow-api-port-windows.ps1 as Administrator).
#
# Option B — if Windows blocks 3000: run `npm run api-proxy` from repo root (forwards LAN :8090 → localhost:3000),
#   add EXPO_PUBLIC_USE_API_PROXY=1 below, allow firewall TCP 8090 (same script with -Port 8090), restart Expo.
EXPO_PUBLIC_API_URL=http://localhost:3000
# EXPO_PUBLIC_USE_API_PROXY=1
# EXPO_PUBLIC_API_PROXY_PORT=8090
#
# Vercel (after deploy — see ../VERCEL.md):
# EXPO_PUBLIC_API_FULL_URL=https://your-project.vercel.app
#
# Google Sign-In — use the same OAuth client IDs as backend/.env (GOOGLE_OAUTH_*).
# Web client ID is required. Add iOS/Android OAuth client IDs for native (especially Android).
# In Google Cloud Console → OAuth 2.0 Client (Web) → Authorized redirect URIs, add what Expo uses:
#   weret:/oauthredirect   (or weret:///oauthredirect — check Metro log if Google returns redirect_uri_mismatch)
#   com.ridehail.app:/oauthredirect   (dev client / release; matches android.package + path)
# Expo Go dev often uses exp://127.0.0.1:PORT/--/oauthredirect — add that exact URL while testing in Go.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
