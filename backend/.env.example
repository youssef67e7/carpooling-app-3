# Vercel: set MONGODB_URI + JWT_SECRET in Project → Settings → Environment Variables (Root Directory = backend).
# Deploy guide: ../VERCEL.md

PORT=3000
# Local MongoDB (Windows/macOS/Linux): run `mongod` or MongoDB Compass service first.
# Cloud (Atlas): mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/ridehail?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/ridehail
JWT_SECRET=change-this-to-a-long-random-string-in-development
# Optional: Google Sign-In (verify ID tokens from app + admin web). Use the Web client ID as primary.
# Comma-separated audiences are built from the non-empty vars below (must match the client that minted the token).
GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_IOS_CLIENT_ID=
GOOGLE_OAUTH_ANDROID_CLIENT_ID=
# Optional: Expo Go / extra OAuth client if you use one
GOOGLE_OAUTH_EXPO_CLIENT_ID=
# Security (see docs/PRODUCTION_ARCHITECTURE.md)
TRUST_PROXY_HOPS=1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
# Fixed admins (only youssef@gmail.com & youssef1@gmail.com may use admin APIs).
# Store bcrypt hashes in production — generate with: npm run hash-admin-password -- "your-secret"
# ADMIN_BCRYPT_YOUSSEF=$2a$12$...
# ADMIN_BCRYPT_YOUSSEF1=$2a$12$...
# Local/dev only (plain passwords — never commit real secrets):
# ADMIN_PASSWORD_YOUSSEF=change-me
# ADMIN_PASSWORD_YOUSSEF1=change-me
